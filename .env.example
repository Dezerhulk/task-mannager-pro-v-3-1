# Copy this file to .env and update values before running the app.
SECRET_KEY=replace-me-with-a-long-random-secret
DATABASE_URL=sqlite:///./tasks.db
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
QUEUE_BACKEND=sqlite
# For PostgreSQL, use:
# DATABASE_URL=postgresql://user:password@localhost:5432/task_db
RATE_LIMIT=5
ACCESS_TOKEN_EXPIRE_SECONDS=3600
LOG_FILE=app.log
ADMIN_PASSWORD=
# USER_CREDENTIALS=alice:alice123,bob:bobPassword,charlie:charliePass
