# Copy this file to .env and update values before running the app.
# IMPORTANT: Generate a secure SECRET_KEY using:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave empty to raise an error on startup if not provided.
SECRET_KEY=
DATABASE_URL=sqlite:///./tasks.db
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
QUEUE_BACKEND=sqlite
# For PostgreSQL, use:
# DATABASE_URL=postgresql://user:password@localhost:5432/task_db
# For Redis queue, set QUEUE_BACKEND=redis and provide REDIS_URL
RATE_LIMIT=5
RATE_LIMIT_WINDOW_SECONDS=60
ACCESS_TOKEN_EXPIRE_SECONDS=3600
LOG_FILE=app.log
ADMIN_PASSWORD=
ALGORITHM=HS256
